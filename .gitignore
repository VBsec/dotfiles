# ============================================================================
# Application Specific
# ============================================================================
# Claude Code (~/.claude)
# Whitelist approach: ignore the whole runtime/state directory, then re-include
# only the files that are genuine, portable user config. Claude Code constantly
# writes new state files/dirs here (sessions, caches, history, tokens, etc.), so
# allow-listing is far more robust than chasing each one.
claude/.claude/*

# Re-include tracked config (negate the ignore above)
!claude/.claude/CLAUDE.md
!claude/.claude/settings.json
!claude/.claude/package.json
!claude/.claude/uninstall-commands.sh
!claude/.claude/gsd-file-manifest.json
# Directories: must un-ignore the dir itself before its contents
!claude/.claude/commands/
!claude/.claude/agents/
!claude/.claude/hooks/
!claude/.claude/skills/
!claude/.claude/get-shit-done/
# Plugins: keep only the declarative config, not installed/cached repos
!claude/.claude/plugins/
claude/.claude/plugins/*
!claude/.claude/plugins/config.json

# Never track secrets/credentials/state (defensive — covered by the * above too)
claude/.claude/.credentials.json
claude/.claude/settings.local.json
claude/.claude/m365-admin*.json
claude/.claude/m365-admin*.pfx
claude/.claude/m365-admin*.pem
claude/.claude/m365-admin*.key
claude/.claude/security_warnings_*.json

# Yazi
yazi/.config/yazi/flavors/*.yazi

# Zed
zed/.config/zed/conversations
zed/.config/zed/prompts/*.mdb

# Ghostty
ghostty/.config/ghostty/themes/

